{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "//": "Shared lint + format config for all TypeScript and Svelte workspaces (MCP servers + dashboard). Each workspace's `lint`/`format` npm scripts call biome; CI runs `npm run lint --workspaces`.",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "**/dist/**",
      "**/build/**",
      "**/.svelte-kit/**",
      "**/node_modules/**",
      "**/*.min.js",
      "dashboard/static/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsoleLog": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn"
      },
      "correctness": {
        "noUnusedVariables": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "//": "Biome cannot fully parse .svelte SFCs; format the embedded <script> only and skip lint rules that misfire on Svelte's compiler-magic ($:, exports). svelte-check (run in CI) covers Svelte type/semantic checks.",
      "include": ["**/*.svelte"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off"
          },
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
