# MatchBox SOC Command Center — Environment Variables
# Copy to .env and fill in credentials

# Wazuh REST API (port 55000, not Dashboard port 5601)
WAZUH_API_URL=https://localhost:55000
WAZUH_DASHBOARD_URL=https://localhost:5601
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=

# Grafana (anonymous viewer access enabled)
GRAFANA_URL=http://localhost:3000

# OpenCTI (GraphQL API)
OPENCTI_URL=http://localhost:4000
OPENCTI_TOKEN=

# TheHive (REST API)
THEHIVE_URL=http://localhost:9000
THEHIVE_API_KEY=

# Cortex (REST API)
CORTEX_URL=http://localhost:9001
CORTEX_API_KEY=

# ── Public (client-exposed) base URLs ──────────────────────────────────────────
# These are read on the BROWSER (iframe embeds + "Open in new tab" links), so they
# must be reachable from wherever the operator's browser runs — not just the server.
# When serving off-localhost (e.g. behind Traefik at soc.homelab.local), point these
# at the externally reachable URLs.
PUBLIC_WAZUH_DASHBOARD_URL=https://localhost:5601
PUBLIC_GRAFANA_URL=http://localhost:3000
PUBLIC_OPENCTI_URL=http://localhost:4000
PUBLIC_THEHIVE_URL=http://localhost:9000
PUBLIC_CORTEX_URL=http://localhost:9001

# ── Dashboard auth ─────────────────────────────────────────────────────────────
# Shared bearer token enforced by src/hooks.server.ts on every /api/* request.
# Without it the proxy leaks full SOC inventory to any LAN client. Generate with
# `openssl rand -hex 32`. Leave blank ONLY for trusted single-host local dev.
SOC_API_TOKEN=

# ── TLS trust (replaces the removed NODE_TLS_REJECT_UNAUTHORIZED=0) ─────────────
# Trust the SOC self-signed CA instead of disabling verification globally. Either:
#   1. set NODE_EXTRA_CA_CERTS to the root-ca.pem path (process-wide, validated), or
#   2. set SOC_CA_CERT below — the Wazuh proxy pins it via a scoped undici dispatcher
#      on its credentialed calls only (other upstreams are plain http://).
# NODE_EXTRA_CA_CERTS=/path/to/root-ca.pem
SOC_CA_CERT=
