# MatchBox — Environment Variables
# Copy to .env and fill in real values. Never commit .env!

# --- SOPS / age secret management ----------------------------------------------
# Path to the age private key used to decrypt k8s/shared/secrets.enc.yaml.
# Created (outside the repo) by ./scripts/setup-sops.sh. deploy-stack.sh reads this
# to decrypt secrets at apply time. NEVER commit the key file itself.
SOPS_AGE_KEY_FILE=$HOME/.config/sops/age/keys.txt

# --- TLS / CA trust ------------------------------------------------------------
# Path to the SOC root CA (root-ca.pem produced by ./scripts/generate-certs.sh).
# Node-based tooling (dashboard, MCP servers) sets this so HTTPS calls to OpenSearch
# and the Wazuh services trust the self-signed SOC CA instead of disabling
# verification. Export it before running those processes.
NODE_EXTRA_CA_CERTS=./certs/root-ca.pem

# --- Dashboard / SOC API auth --------------------------------------------------
# Shared bearer token enforced by the dashboard's /api/* routes (src/hooks.server.ts).
# Generate a long random value: `openssl rand -hex 32`.
SOC_API_TOKEN=

# Traefik ingress basic-auth (consumed by deploy-stack.sh deploy_ingress()).
# If SOC_BASIC_AUTH_PASSWORD is unset, deploy generates a random one and prints it.
SOC_BASIC_AUTH_USER=admin
SOC_BASIC_AUTH_PASSWORD=

# --- Wazuh Server API (MCP server: /agents, /rules, /decoders) -----------------
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=

# --- Wazuh Indexer / OpenSearch (MCP server: alerts + vulnerabilities) ---------
# Alerts and vulnerability states live in the Wazuh Indexer (OpenSearch, :9200),
# NOT the Server API. The wazuh-mcp server queries these for list-alerts / get-alert
# / get-vulnerabilities.
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=

# --- TheHive API (MCP server) --------------------------------------------------
THEHIVE_URL=https://localhost:9000
THEHIVE_API_KEY=

# --- OpenCTI API (MCP server) --------------------------------------------------
OPENCTI_URL=https://localhost:4000
OPENCTI_TOKEN=

# --- OpenCTI platform admin (consumed by deploy-stack.sh deploy_opencti()) -----
# Required at deploy time. Token should be a UUID; password >= 12 chars.
OPENCTI_ADMIN_TOKEN=
OPENCTI_ADMIN_PASSWORD=
# Optional: health-check access key (a random one is generated if unset).
OPENCTI_HEALTH_KEY=

# --- Threat Intelligence API Keys ----------------------------------------------
# Optional. A connector whose key is unset is simply not deployed (no junk
# 'placeholder' secret, no crash-looping connector).
ALIENVAULT_OTX_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Cortex API (for TheHive integration) --------------------------------------
CORTEX_API_KEY=
