{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // Executable app — nothing consumes its .d.ts, so don't emit declarations.
    "declaration": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"]
}
