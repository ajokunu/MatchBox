# OpenCTI MCP Server — Environment Variables

# Must match the in-code default and the deployed ingress path.
OPENCTI_URL=https://soc.homelab.local/opencti
OPENCTI_TOKEN=

# --- TLS for the self-signed SOC CA ---
# Trust the SOC root CA so HTTPS is verified (do NOT disable verification globally).
NODE_EXTRA_CA_CERTS=/path/to/root-ca.pem

# --- Optional tuning (defaults shown) ---
# REQUEST_TIMEOUT_MS=10000
# REQUEST_DEADLINE_MS=21000
# MAX_RESPONSE_CHARS=50000
# MAX_RETRIES=1
