# Wazuh MCP Server — Environment Variables
#
# Two distinct backends:
#  - Server API (:55000): agents, rules, decoders
#  - Indexer/OpenSearch (:9200): alerts, vulnerabilities (via _search)

# --- Server API (agents / rules / decoders) ---
WAZUH_API_URL=https://soc.homelab.local:55000
WAZUH_API_USER=
WAZUH_API_PASSWORD=

# --- Indexer / OpenSearch (alerts / vulnerabilities) ---
# list-alerts, get-alert, get-vulnerabilities query the indexer, NOT the Server API.
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=
# Optional index pattern overrides (defaults shown):
# WAZUH_ALERTS_INDEX=wazuh-alerts-*
# WAZUH_VULN_INDEX=wazuh-states-vulnerabilities-*

# --- TLS for the self-signed SOC CA ---
# Point Node at the SOC root CA so HTTPS to the self-signed endpoints is TRUSTED
# without disabling verification. NEVER set NODE_TLS_REJECT_UNAUTHORIZED=0 — it
# would MITM-expose the admin credentials this server sends.
NODE_EXTRA_CA_CERTS=/path/to/root-ca.pem

# --- Optional tuning (defaults shown) ---
# REQUEST_TIMEOUT_MS=10000      # per-attempt HTTP timeout
# REQUEST_DEADLINE_MS=21000     # overall deadline across retries
# MAX_RESPONSE_CHARS=50000      # response truncation budget sent to the LLM
# MAX_RETRIES=1                 # retries on the first attempt for transient failures
# TOKEN_TTL_MS=850000           # fallback JWT cache TTL when the token has no exp claim
