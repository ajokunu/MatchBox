# Kubernetes Secrets Template for MatchBox.
# Copy to k8s/shared/secrets.yaml (gitignored), fill in real base64 values, then run
# `make secrets-init` to produce the committable SOPS-encrypted k8s/shared/secrets.enc.yaml.
#
# To encode a value WITHOUT writing plaintext into ~/.zsh_history / ~/.bash_history,
# do NOT use `echo -n "secret" | base64`. Prefer:
#   read -rs SECRET; printf %s "$SECRET" | base64
# or `kubectl create secret generic ... --from-file=KEY=path`.
#
# NOTE: K8s Secrets are base64 (not encrypted) at rest unless k3s secrets-encryption
# is enabled (`--secrets-encryption`). Use the SOPS path for anything committed.
# NEVER commit this file (or secrets.yaml) with real values.
---
apiVersion: v1
kind: Secret
metadata:
  name: soc-shared-secrets
  namespace: shared
  labels:
    app.kubernetes.io/part-of: matchbox-soc
type: Opaque
data:
  # OpenSearch admin password
  # echo -n "CHANGE_ME_OPENSEARCH" | base64
  opensearch-password: Q0hBTkdFX01FX09QRU5TRUFSQ0g=
  # Redis password
  # echo -n "CHANGE_ME_REDIS" | base64
  redis-password: Q0hBTkdFX01FX1JFRElT
  # RabbitMQ password
  # echo -n "CHANGE_ME_RABBITMQ" | base64
  rabbitmq-password: Q0hBTkdFX01FX1JBQkJJVE1R
  # RabbitMQ Erlang cookie
  # echo -n "CHANGE_ME_ERLANG_COOKIE" | base64
  rabbitmq-erlang-cookie: Q0hBTkdFX01FX0VSTEFOR19DT09LSUU=
  # MinIO root user
  # echo -n "minio-admin" | base64
  minio-root-user: bWluaW8tYWRtaW4=
  # MinIO root password
  # echo -n "CHANGE_ME_MINIO" | base64
  minio-root-password: Q0hBTkdFX01FX01JTklP
---
apiVersion: v1
kind: Secret
metadata:
  name: soc-opencti-secrets
  namespace: opencti
  labels:
    app.kubernetes.io/part-of: matchbox-soc
type: Opaque
data:
  # OpenCTI admin password
  admin-password: Q0hBTkdFX01FX09QRU5DVEk=
  # OpenCTI admin token (retrieve after first boot)
  admin-token: Q0hBTkdFX01F
  # AlienVault OTX API key (register at https://otx.alienvault.com)
  alienvault-api-key: Q0hBTkdFX01F
  # AbuseIPDB API key (register at https://www.abuseipdb.com/api)
  abuseipdb-api-key: Q0hBTkdFX01F
  # VirusTotal API key (register at https://www.virustotal.com/gui/join-us)
  virustotal-api-key: Q0hBTkdFX01F
  # OpenCTI health endpoint access key
  # echo -n "CHANGE_ME_HEALTH" | base64
  health-access-key: Q0hBTkdFX01FX0hFQUxUSA==
---
apiVersion: v1
kind: Secret
metadata:
  name: soc-thehive-secrets
  namespace: thehive
  labels:
    app.kubernetes.io/part-of: matchbox-soc
type: Opaque
data:
  # NOTE: no api-key here — nothing consumes soc-thehive-secrets/api-key. TheHive's
  # REST API key is generated in-app post-login; the Cortex link uses cortex-api-key.
  # TheHive Play framework secret (use a long random value; rotate per environment).
  play-secret: Q0hBTkdFX01FX1BMQVk=
  # Cortex API key — placeholder until Cortex is running and an org user/key exists.
  cortex-api-key: Q0hBTkdFX01F
---
apiVersion: v1
kind: Secret
metadata:
  name: soc-grafana-secrets
  namespace: monitoring
  labels:
    app.kubernetes.io/part-of: matchbox-soc
type: Opaque
data:
  # Grafana admin password
  admin-password: Q0hBTkdFX01FX0dSQUZBTkE=
  admin-user: YWRtaW4=
---
apiVersion: v1
kind: Secret
metadata:
  name: soc-wazuh-secrets
  namespace: wazuh
  labels:
    app.kubernetes.io/part-of: matchbox-soc
type: Opaque
data:
  wazuh-api-password: Q0hBTkdFX01FX1dBWlVI     # CHANGE_ME_WAZUH
  # indexer-password = the OpenSearch admin password mirrored into the wazuh ns
  # (secretKeyRefs cannot cross namespaces). MUST equal soc-shared-secrets/opensearch-password.
  # Wazuh's manager Filebeat authenticates to the shared OpenSearch with this.
  # echo -n "CHANGE_ME_OPENSEARCH" | base64   (same value as opensearch-password)
  indexer-password: Q0hBTkdFX01FX09QRU5TRUFSQ0g=
  # registration-password = Wazuh agent enrollment password for authd (use_password=yes).
  # Seeded into /var/ossec/etc/authd.pass by the manager initContainer and passed to the
  # agent DaemonSet as WAZUH_REGISTRATION_PASSWORD. Use a long random shared value.
  # echo -n "CHANGE_ME_ENROLLMENT" | base64
  registration-password: Q0hBTkdFX01FX0VOUk9MTE1FTlQ=
